LITELLM_BASE_URL=https://your-litellm-proxy.example.com
LITELLM_API_KEY=your-server-only-key
LITELLM_MODEL=anthropic/claude-sonnet-5

# Create with: openssl rand -base64 32
PREVIEW_SESSION_SECRET=replace-with-a-random-server-only-secret
# Create with: npm run preview:snapshot
VERCEL_SANDBOX_SNAPSHOT_ID=snap_replace_me
PREVIEW_SANDBOX_TIMEOUT_MINUTES=40
